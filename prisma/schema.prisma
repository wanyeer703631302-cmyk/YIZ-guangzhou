// Prisma Schema for Backend Integration Migration
// This schema defines all data models for the full-stack application

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User role enumeration
enum UserRole {
  ADMIN
  USER
}

// Audit action enumeration
enum AuditAction {
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_ROLE_CHANGED
  USER_PASSWORD_RESET
  USER_PASSWORD_CHANGED
  USER_LOGIN
  USER_LOGOUT
}

// User model - stores user authentication and profile information
model User {
  id                    String   @id @default(cuid())
  email                 String   @unique
  name                  String
  password              String
  role                  UserRole @default(USER)
  isActive              Boolean  @default(true)
  requirePasswordChange Boolean  @default(false)
  createdBy             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  assets           Asset[]
  likes            Like[]
  favorites        Favorite[]
  folders          Folder[]
  creator          User?      @relation("UserCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  createdUsers     User[]     @relation("UserCreator")
  performedAudits  AuditLog[] @relation("PerformedBy")
  targetedAudits   AuditLog[] @relation("TargetUser")

  @@map("users")
}

// Asset model - stores image/media assets
model Asset {
  id           String   @id @default(cuid())
  title        String
  url          String
  thumbnailUrl String
  size         Int
  folderId     String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder    Folder?    @relation(fields: [folderId], references: [id], onDelete: SetNull)
  likes     Like[]
  favorites Favorite[]
  tags      AssetTag[]

  // Indexes for performance
  @@index([userId])
  @@index([folderId])
  @@index([createdAt])
  @@map("assets")
}

// Folder model - organizes assets into folders
model Folder {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets Asset[]

  // Indexes
  @@index([userId])
  @@map("folders")
}

// Tag model - stores unique tags for categorization
model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  // Relations
  assets AssetTag[]

  @@map("tags")
}

// AssetTag model - many-to-many relationship between assets and tags
model AssetTag {
  assetId String
  tagId   String

  // Relations
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([assetId, tagId])
  @@map("asset_tags")
}

// Like model - stores user likes on assets
model Like {
  id        String   @id @default(cuid())
  assetId   String
  userId    String
  createdAt DateTime @default(now())

  // Relations
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Unique constraint to prevent duplicate likes
  @@unique([assetId, userId])
  // Indexes for performance
  @@index([userId])
  @@index([assetId])
  @@map("likes")
}

// Favorite model - stores user favorites on assets
model Favorite {
  id        String   @id @default(cuid())
  assetId   String
  userId    String
  createdAt DateTime @default(now())

  // Relations
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Unique constraint to prevent duplicate favorites
  @@unique([assetId, userId])
  // Indexes for performance
  @@index([userId])
  @@index([assetId])
  @@map("favorites")
}

// AuditLog model - stores audit trail of user management operations
model AuditLog {
  id            String      @id @default(cuid())
  action        AuditAction
  performedById String
  targetUserId  String?
  details       Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime    @default(now())

  // Relations
  performedBy User  @relation("PerformedBy", fields: [performedById], references: [id], onDelete: Cascade)
  targetUser  User? @relation("TargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  // Indexes for performance
  @@index([performedById])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
