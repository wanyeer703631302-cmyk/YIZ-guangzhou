{
  "manifest_version": 3,
  "name": "PinCollect 采集",
  "version": "0.1.0",
  "description": "在任意网页采集图片到你的站点",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": { "default_title": "采集图片" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
